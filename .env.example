# ============================================================
# .env.example — copy to .env and fill in your values.
#
# The .env file is loaded automatically by config.Load().
# OS environment variables always take precedence over .env values,
# so production deployments can inject secrets via the environment
# without ever having a .env file on disk.
#
# NEVER commit .env to version control — it is listed in .gitignore.
# ============================================================


# ── Database (required) ──────────────────────────────────────────────────────
#
# Standard PostgreSQL connection string accepted by pgx.
# Format: postgres://<user>:<password>@<host>:<port>/<dbname>?<options>
#
DATABASE_URL=postgres://postgres:postgres@localhost:5432/workforce_planning?sslmode=disable


# ── HTTP server (optional) ───────────────────────────────────────────────────
#
# TCP port the server listens on.
# Default: 8080
#
PORT=8080

# Minimum log level: debug | info | warn | error
# Default: info
#
LOG_LEVEL=info


# ── Authentication (optional — required once JWT auth is implemented) ────────
#
# Secret key used to sign and verify JWT tokens.
# Must be at least 32 random bytes in production.
# Generate a value: openssl rand -hex 32
#
JWT_SECRET=change-me-to-a-random-secret-before-production
